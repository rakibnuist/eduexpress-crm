{
  "name": "EduExpress — Publishing Engine v2",
  "nodes": [
    {
      "parameters": {
        "path": "eduexpress-publish",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-trigger",
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1.1,
      "position": [260, 340],
      "webhookId": "eduexpress-publish"
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json.body || $input.first().json;\n\n// Validate required fields\nconst required = ['postId', 'page', 'platform', 'body'];\nconst missing = required.filter(k => !input[k]);\nif (missing.length > 0) {\n  return [{\n    json: {\n      success: false,\n      error: `Missing required fields: ${missing.join(', ')}`,\n      postId: input.postId\n    }\n  }];\n}\n\n// Page ID mapping (configured via env or credentials)\nconst pageMap = {\n  'china': $env.FB_PAGE_CHINA_ID || '',\n  'bd': $env.FB_PAGE_BD_ID || '',\n  'BD': $env.FB_PAGE_BD_ID || '',\n  'main': $env.FB_PAGE_BD_ID || ''\n};\n\nconst pageId = pageMap[input.page];\nif (!pageId && input.platform === 'facebook') {\n  return [{\n    json: {\n      success: false,\n      error: `Unknown page: ${input.page}. Configure FB_PAGE_CHINA_ID or FB_PAGE_BD_ID env vars.`,\n      postId: input.postId\n    }\n  }];\n}\n\n// Build the publish payload\nconst payload = {\n  postId: input.postId,\n  pageId: pageId,\n  page: input.page,\n  platform: input.platform,\n  body: input.body,\n  assetUrl: input.assetUrl || null,\n  hashtags: input.hashtags || '',\n  cta: input.cta || '',\n  crmBase: input.crmBase || $env.CRM_BASE || 'https://crm.eduexpressint.com',\n  crmKey: input.crmKey || $env.CRM_KEY || 'eduexpress-n8n-2024',\n  scheduledAt: input.scheduledAt || new Date().toISOString()\n};\n\nreturn [{ json: payload }];"
      },
      "id": "validate-input",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 340]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "has-error",
              "leftValue": "={{ $json.success }}",
              "rightValue": false,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "has-error",
      "name": "Has Error?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [660, 240]
    },
