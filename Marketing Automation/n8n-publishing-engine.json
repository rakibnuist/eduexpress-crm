      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [860, 240]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n// Build publish result from FB response\nconst fbResponse = $input.first().json;\nconst postId = fbResponse.id || fbResponse.post_id;\nconst success = !!postId;\nreturn [{\n  json: {\n    success: success,\n    postId: $json.postId,\n    platformPostId: postId,\n    publishUrl: postId ? `https://facebook.com/${postId}` : null,\n    platform: $json.platform,\n    page: $json.page,\n    error: success ? null : (fbResponse.error?.message || 'Unknown error'),\n    rawResponse: fbResponse\n  }\n}];"
      },
      "id": "build-result",
      "name": "Build Result",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1060, 340]
    },
